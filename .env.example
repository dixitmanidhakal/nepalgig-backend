# NepalgGig Backend — copy to .env

# ── Database ─────────────────────────────────────────────
POSTGRES_DB=nepalgig
POSTGRES_USER=nepalgig_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://nepalgig_user:CHANGE_ME@localhost:5432/nepalgig

# ── Redis (rate limiting & session cache) ────────────────
REDIS_URL=redis://:REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── App ──────────────────────────────────────────────────
NODE_ENV=production
APP_BASE_URL=https://nepalgig.com
PORT=4000

# ── Session ──────────────────────────────────────────────
NEXTAUTH_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING
SESSION_TTL_DAYS=30
MAGIC_LINK_TTL_MINUTES=15

# ── Email (Magic Links) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=NepalgGig <noreply@nepalgig.com>

# ── Rate Limits ──────────────────────────────────────────
RATE_LIMIT_MAGIC_LINK=3
RATE_LIMIT_API=30

# ── Platform Config ──────────────────────────────────────
PLATFORM_FEE_PERCENT=5
MIN_GIG_AMOUNT_NPR=100
DEVICE_FINGERPRINT_SALT=CHANGE_ME_UNIQUE_SALT
